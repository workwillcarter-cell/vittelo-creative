generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CEO
  AI_GENERATOR
  EDITOR
}

enum Stage {
  IDEATION
  READY
  AI_GENERATION
  AI_REVIEW
  EDITING
  EDITOR_REVIEW
  LAUNCHED
  PERFORMANCE_REVIEW
  COMPLETED
}

enum Result {
  FAILED
  WINNER
  BIG_WINNER
  SPENT_BUT_POOR_PERFORMANCE
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(EDITOR)
  createdAt DateTime @default(now())

  batches   Batch[]
  creatives Creative[]
  history   StageHistory[]
}

model Batch {
  id          String     @id @default(cuid())
  name        String
  number      Int?
  description String?
  sealed      Boolean    @default(false)
  createdAt   DateTime   @default(now())
  createdById String
  createdBy   User       @relation(fields: [createdById], references: [id])

  creatives Creative[]
}

model Creative {
  id             String   @id @default(cuid())
  concept        String
  briefLink      String?
  finishedAdLink String?
  learnings      String?
  stage          Stage    @default(IDEATION)
  adNumber       String?
  launchDate     DateTime?
  result         Result?
  spend          Float?
  roas           Float?
  extraInfo      String?
  ceoStatus        String?
  aigStatus        String?
  projectType      String?
  style            String?
  aigNotes         String?
  needsRevision    Boolean  @default(false)
  revisionDetails  String?
  revisionComplete Boolean  @default(false)

  editorStatus           String?
  editorNotes            String?
  editorNeedsRevision    Boolean  @default(false)
  editorRevisionDetails  String?
  editorRevisionComplete Boolean  @default(false)
  editorDriveLink        String?
  usedInAd               String?

  transferStatus String?
  transferError  String?
  transferredAt  DateTime?
  dropboxPath    String?

  batchId     String?
  batch       Batch?  @relation(fields: [batchId], references: [id])
  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  history StageHistory[]
}

model StageHistory {
  id          String   @id @default(cuid())
  creativeId  String
  creative    Creative @relation(fields: [creativeId], references: [id])
  fromStage   Stage?
  toStage     Stage
  changedById String
  changedBy   User     @relation(fields: [changedById], references: [id])
  note        String?
  changedAt   DateTime @default(now())
}

model IntegrationToken {
  provider     String   @id
  refreshToken String
  accessToken  String?
  expiresAt    DateTime?
  updatedAt    DateTime @updatedAt
}
